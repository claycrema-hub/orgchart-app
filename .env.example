# ZoomInfo API credentials
# Get these from your ZoomInfo admin panel → API Settings
ZOOMINFO_USERNAME=your_email@company.com
ZOOMINFO_PASSWORD=your_zoominfo_api_password
ZOOMINFO_CLIENT_ID=your_client_id

# Clay API key (optional — used as fallback enrichment)
# Get from clay.com → Settings → API
CLAY_API_KEY=your_clay_api_key

# Brave Search API key (optional — used for web leadership scraping)
# Get from api.search.brave.com
BRAVE_SEARCH_API_KEY=your_brave_key
